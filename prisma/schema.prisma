generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
    output = "/home/ubuntu/phpi_content_hub/nextjs_space/node_modules/.prisma/client"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

// NextAuth Models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          String    @default("user")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Content Hub Models
model Article {
  id           String            @id @default(cuid())
  title        String
  emoji        String?           // Emoji to display before title
  originalUrl  String            @unique
  rawContent   String?           @db.Text
  aiSummary    String?           @db.Text
  aiFullPost   String?           @db.Text
  status       ArticleStatus     @default(DRAFT)
  isStarred    Boolean           @default(false)
  publishedAt  DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  
  // Video-specific fields
  isVideo      Boolean           @default(false)
  videoId      String?
  thumbnailUrl String?
  channelName  String?
  
  // Article images
  images       String[]          @default([])
  featuredImage String?
  
  categories   ArticleCategory[]
  tags         ArticleTag[]
  sources      AdditionalSource[]
}

model AdditionalSource {
  id          String   @id @default(cuid())
  articleId   String
  title       String
  url         String
  description String?  @db.Text
  approved    Boolean  @default(false) // Whether admin approved this source
  order       Int      @default(0)     // Display order
  createdAt   DateTime @default(now())
  
  article     Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  
  @@unique([articleId, url])
}

model Category {
  id          String            @id @default(cuid())
  name        String            @unique
  slug        String            @unique
  description String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  articles    ArticleCategory[]
}

model Tag {
  id        String       @id @default(cuid())
  name      String       @unique
  slug      String       @unique
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  articles  ArticleTag[]
}

model ArticleCategory {
  id         String   @id @default(cuid())
  articleId  String
  categoryId String
  article    Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([articleId, categoryId])
}

model ArticleTag {
  id        String   @id @default(cuid())
  articleId String
  tagId     String
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([articleId, tagId])
}

model RSSFeed {
  id              String    @id @default(cuid())
  name            String
  feedUrl         String    @unique
  lastFetchedAt   DateTime?
  autoFetchEnabled Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

enum ArticleStatus {
  DRAFT
  APPROVED
  PUBLISHED
  REJECTED
}
