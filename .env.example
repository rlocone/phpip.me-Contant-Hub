# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/phipi_me?schema=public

# NextAuth
NEXTAUTH_SECRET=generate-with-openssl-rand-hex-32
NEXTAUTH_URL=https://phipi.me

# Google OAuth
GOOGLE_CLIENT_ID=your-client-id
GOOGLE_CLIENT_SECRET=your-client-secret

# API Keys
VENICE_API_KEY=your-venice-key
ABACUSAI_API_KEY=your-abacus-key

# Seed script (production seed only — never hardcode passwords)
SEED_ADMIN_PASSWORD=CHANGEME
SEED_ADMIN_EMAIL=admin@phipi.tech
SEED_ADMIN_NAME=Admin User

# Signup gate (set a secret to enable signup; leave unset to disable)
SIGNUP_SECRET=

# RSS feed contact (defaults to admin@phipi.tech if unset)
SITE_EMAIL=admin@phipi.tech

# AWS S3 (for image uploads)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=